# ──────────────────────────────────────────────────────────────────────────
# Global Football Activity Tracker — environment
# Copy this file to `.env` and fill in the values. The UI renders without
# these (you'll see a setup notice); they're required for data sync.
# ──────────────────────────────────────────────────────────────────────────

# Postgres connection string. Neon (neon.tech) gives you this for free.
# Local dev:  postgresql://user:pass@localhost:5432/football
# Neon:       postgresql://user:pass@ep-xxx.neon.tech/football?sslmode=require
DATABASE_URL=

# API-Football (api-sports.io) API key. Free signup at https://api-sports.io
API_FOOTBALL_KEY=

# Upstream base URL. Use the direct endpoint (default); set to a RapidAPI
# proxy URL if you obtained your key via RapidAPI instead.
# API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Free tier = 100 requests/day. Bump this when you upgrade to a paid plan
# (Pro = 7500/day, Mega = 75000/day). Enforced by the sync client.
# API_FOOTBALL_DAILY_LIMIT=100

# Your deployed URL (used for absolute links / OG tags). Optional in dev.
# APP_URL=http://localhost:3000
